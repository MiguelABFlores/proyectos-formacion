{
  "name": "tabla-periodica-biblia",
  "version": "0.1.0",
  "private": true,
  "description": "Juego tipo Kahoot con temática de tabla periódica de los libros de la Biblia",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist-server/index.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.1",
    "zod": "^3.23.8",
    "qrcode.react": "^4.1.0",
    "nanoid": "^5.0.9",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
