# Plantilla de overrides de variables.
#
# Cómo usar:
#   1. cp terraform.tfvars.example terraform.tfvars
#   2. edita terraform.tfvars con tus valores
#   3. terraform.tfvars está en .gitignore — NO se commitea
#
# Si te sirven todos los defaults de variables.tf, puedes saltarte este paso
# y ejecutar `terraform apply` directamente.

# Región de AWS. Cualquier región funciona, pero us-east-1 es la más barata.
# aws_region = "us-east-1"

# Tipo de instancia. t3.micro es free tier. Si necesitas más músculo:
#   t3.small  ≈ $15/mes (2 GB RAM)
#   t3.medium ≈ $30/mes (4 GB RAM)
# instance_type = "t3.micro"

# Si haces un fork del repo, cámbialo aquí.
# github_repo   = "https://github.com/MiguelABFlores/proyectos-formacion.git"
# github_branch = "main"
